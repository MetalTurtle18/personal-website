---
import Layout from './Layout.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  summary?: string;
  pubDate: Date;
  updateDate?: Date;
  chronoDate?: Date;
  author: string;
  image?: { url: string; alt: string };
  type: 'blog' | 'projects';
  draft: boolean;
}

const { title, summary, pubDate, updateDate, chronoDate, author, image, draft } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdateDate = updateDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedChronoDate = chronoDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<Layout title={title}>
  {draft && <div class="draft-notice">This article is a draft.</div>}
  <article class="markdown-post">
    {
      image && (
        <div class="hero-image">
          <Image src={image.url} alt={image.alt} inferSize={true} />
        </div>
      )
    }
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {summary ? <h3 class="post-summary">{summary}</h3> : null}
      <div class="post-meta">
        <span>
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          {
            updateDate && (
              <>
                <span class="meta-separator">•</span> <span>updated</span>{' '}
                <time datetime={updateDate.toISOString()}>{formattedUpdateDate}</time>
              </>
            )
          }
          <span class="meta-separator">•</span>
          <span class="author">{author}</span>
        </span>
      </div>
      {
        chronoDate && (
          <div class="chrono-date">
            <p>
              <span>This subject of this article occurred in</span>
              <time datetime={chronoDate.toISOString()}>{`${formattedChronoDate}.`}</time>
              <a href="/blog/writing-project-articles#dating-new-articles-for-old-projects">
                Learn more about how I sort articles chronologically.
              </a>
            </p>
          </div>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>

<style>
  a {
    color: #047857;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .draft-notice {
    top: 0;
    left: 0;
    width: 100%;
    padding: 0.6rem 0rem;
    background: #f34c4c;
    color: #ffffff;
    font-size: 0.9rem;
    text-align: center;
    font-weight: bold;
    border-bottom: 1px solid #280202;
    z-index: 999;
  }

  .markdown-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e5e5;
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  .post-title {
    margin: 0 0 1rem 0;
    font-size: 2.5rem;
    color: #000;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    align-items: center;
    font-size: 0.95rem;
    color: #777;
    margin-bottom: 1rem;
  }

  .meta-separator {
    color: #ccc;
  }

  .author {
    color: #777;
  }

  .chrono-date {
    text-align: center;
    background: white;
    border: 1px solid #047857;
    border-radius: 0.75rem;
    width: fit-content;
    margin: 0 0;
  }

  .chrono-date p {
    color: #6b7280;
    font-size: 0.7rem;
    padding: 0 0.3rem;
    margin: 0.5rem 0;
  }

  .prose {
    font-family:
      'Outfit',
      system-ui,
      -apple-system,
      sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #333;
  }

  /* Drop cap styling for first paragraph */
  .prose :global(> p:first-of-type::first-letter) {
    float: left;
    font-size: 3.45em;
    line-height: 0.85;
    margin-right: 0.1em;
    margin-top: 0.1em;
    color: #047857;
    font-weight: 700;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    color: #000;
  }

  .prose :global(h1) {
    font-size: 2rem;
  }

  .prose :global(h2) {
    font-size: 1.75rem;
  }

  .prose :global(h3) {
    font-size: 1.5rem;
  }

  .post-summary {
    font-weight: normal;
  }

  .prose :global(p) {
    margin: 1rem 0;
  }

  .prose :global(a) {
    color: #047857;
    text-decoration: none;
  }

  .prose :global(a:hover) {
    color: #065f46;
    text-decoration: underline;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .prose :global(li) {
    margin: 0.5rem 0;
  }

  .prose :global(code) {
    background: #f5f5f5;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
  }

  .prose :global(pre) {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid #e5e5e5;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #555;
    font-style: italic;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1.5rem 0;
  }

  /* Anchor link styles for heading permalinks */
  .prose :global(.anchor) {
    position: relative;
  }

  .prose :global(.anchor-link) {
    position: absolute;
    left: -1.8rem;
    padding-right: 0.5rem;
    opacity: 0.1;
    transition: opacity 0.2s ease;
  }

  .prose :global(.anchor:hover .anchor-link) {
    opacity: 1;
  }

  .prose :global(.heading-anchor-icon) {
    vertical-align: baseline;
    display: inline-block;
  }

  .prose :global(.anchor-link):global(.copied) {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .markdown-post {
      padding: 1.5rem 1rem;
    }

    .post-title {
      font-size: 2rem;
    }

    .prose {
      font-size: 1rem;
    }

    .prose :global(h1) {
      font-size: 1.75rem;
    }

    .prose :global(h2) {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 870px) {
    .prose :global(h1.anchor),
    .prose :global(h2.anchor),
    .prose :global(h3.anchor),
    .prose :global(h4.anchor),
    .prose :global(h5.anchor),
    .prose :global(h6.anchor) {
      display: flex;
      flex-direction: row-reverse;
      justify-content: flex-end;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      max-width: 100%;
      clear: both;
    }

    .prose :global(.anchor-link) {
      position: static;
      flex-shrink: 0;
    }
  }
</style>

<style is:global>
  article iframe[src*='youtube.com'],
  article iframe[src*='youtu.be'] {
    width: 100% !important;
    max-width: 100% !important;
    aspect-ratio: 16 / 9 !important;
    height: auto !important;

    /* The Fix for Corners */
    border-radius: 12px !important;
    border: none !important;
    overflow: hidden !important;

    transition: all 0.2s ease;

    margin: 2rem 0;
  }

  article iframe[src*='youtube.com']:hover,
  article iframe[src*='youtu.be']:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  :target {
    background-color: #d1fae5;
    border-left: 4px solid #047857;
    padding-left: 0.75rem;
    margin-left: -0.75rem !important;
    transition: all 0.3s ease;
    scroll-margin-top: 30px; /* Adjust based on your header height */
  }

  .prose .anchor-link.copied::after {
    content: 'Copied URL';
    position: absolute;
    transform: translateY(-1.5rem);
    font-size: 0.65rem;
    background: #047857;
    color: #d1fae5;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  @media (max-width: 870px) {
    .prose .anchor-link.copied::after {
      content: 'Copied URL';
      position: absolute;
      transform: translateY(-1.5rem) translateX(-5rem);
      font-size: 0.65rem;
      background: #047857;
      color: #d1fae5;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      white-space: nowrap;
    }
  }
</style>

<script>
  // Target the links generated by rehype-autolink-headings
  const headerLinks = document.querySelectorAll(
    'article h1 a, article h2 a, article h3 a, article h4 a, article h5 a, article h6 a'
  );

  headerLinks.forEach((link) => {
    link.addEventListener('click', async (e) => {
      // Get the full URL: https://yoursite.com/post#header-id
      const url = new URL(window.location.href);
      url.hash = link.getAttribute('href') || '';

      try {
        await navigator.clipboard.writeText(url.toString());

        // Optional: Show a temporary "Copied!" tooltip or icon change
        const originalText = link.innerHTML;
        link.classList.add('copied');

        setTimeout(() => {
          link.classList.remove('copied');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy link:', err);
      }
    });
  });
</script>
